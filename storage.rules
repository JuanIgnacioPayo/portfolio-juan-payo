rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read images (public portfolio)
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Only the owner can upload/delete images
    match /profiles/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.token.email == 'elpatiodesalcedo@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    match /projects/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.token.email == 'elpatiodesalcedo@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    match /uploads/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.token.email == 'elpatiodesalcedo@gmail.com'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
